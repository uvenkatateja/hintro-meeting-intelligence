# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/hintro

# Secret key for signing JWT tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT expiry duration (e.g., "7d" for 7 days, "24h" for 24 hours)
JWT_EXPIRES_IN=7d

# API key for Groq AI service
GROQ_API_KEY=your-groq-api-key

# API key for Resend email service
RESEND_API_KEY=your-resend-api-key

# Sender email address for reminder emails (must be from your verified domain)
RESEND_FROM_EMAIL=noreply@triadforge.xyz

# Redis connection string
REDIS_URL=redis://localhost:6379

# Server port
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# Cron schedule for overdue reminder job (default: every hour)
REMINDER_CRON=0 * * * *
